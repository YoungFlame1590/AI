      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nconst stakeholders = body.stakeholders ?? [\n  { id: 'clerk', name: '门店店员' },\n  { id: 'manager', name: '门店店长' },\n  { id: 'operation', name: '总部运营管理员' },\n  { id: 'finance', name: '财务人员' },\n  { id: 'customer', name: '客户' },\n  { id: 'delivery', name: '配送/外协人员' },\n  { id: 'admin', name: '系统管理员' }\n];\nif (!body.apiKey) throw new Error('缺少 apiKey，请在启动 Webhook 请求体中传入百炼 API key。');\nreturn [{ json: {\n  projectName: body.projectName ?? '图文快印门店连锁管理系统',\n  apiKey: body.apiKey,\n  agentBaseUrl: (body.agentBaseUrl ?? 'http://127.0.0.1:8000').replace(/\\/$/, ''),\n  stakeholders,\n  roundsPerStakeholder: Number(body.roundsPerStakeholder ?? 1),\n  acceptA5Risks: Boolean(body.acceptA5Risks ?? false),\n  ccbConclusion: body.ccbConclusion ?? '通过（无保留意见）'\n}}];"
      }
    },
    {
      "id": "a1b-batch",
      "name": "A1b 批量访谈并保存",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
