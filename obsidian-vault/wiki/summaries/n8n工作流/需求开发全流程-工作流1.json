    {
      "id": "record-ccb",
      "name": "记录CCB审批请求",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2240,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $('准备执行参数').first().json.agentBaseUrl }}/api/n8n/ccb-pending",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ (() => { const base = $execution.resumeUrl; const suffix = '/ccb-approval'; const i = base.indexOf('?'); const resumeUrl = i === -1 ? base + suffix : base.slice(0, i) + suffix + base.slice(i); return { resumeUrl, executionId: $execution.id, workflowName: '需求开发全流程（工作流1）', latestSrs: $('A4 SRS 生成').first().json.relativePath, latestA5Report: $('A5 需求验证').first().json.relativePath, a5Decision: $('A5 需求验证').first().json.decision, a5Summary: $('A5 需求验证').first().json.message || $('A5 需求验证').first().json.summary }; })() }}",
        "options": {
          "timeout": 120000
        }
      }
    },
    {
      "id": "ccb-wait",
      "name": "CCB审批等待",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        2520,
        0
      ],
      "parameters": {
        "resume": "webhook",
        "httpMethod": "POST",
        "responseMode": "onReceived",
        "responseCode": 200,
        "responseData": "firstEntryJson",
        "options": {
          "webhookSuffix": "ccb-approval"
        }
      }
    },
    {
      "id": "parse-ccb",
      "name": "解析CCB决策",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2800,
        0
      ],
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nconst decision = body.decision ?? 'revise';\nconst comments = body.comments ?? '';\nconst acceptA5Risks = decision === 'approvedWithRisk' || body.acceptA5Risks === true;\nconst shouldCreateBaseline = decision === 'approved' || decision === 'approvedWithRisk';\nreturn [{ json: {\n  decision,\n  comments,\n  acceptA5Risks,\n  shouldCreateBaseline,\n  ccbConclusion: comments || (decision === 'approvedWithRisk' ? 'CCB 带风险批准' : 'CCB 审批通过')\n}}];"
      }
    },
    {
      "id": "if-create-baseline",
      "name": "是否创建基线",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        3080,
        0
      ],
      "parameters": {
        "conditions": {
          "combinator": "and",
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "ccb-should-create",
              "leftValue": "={{ $json.shouldCreateBaseline }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "a6-create",
      "name": "A6 创建需求基线",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3360,
        -120
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $('准备执行参数').first().json.agentBaseUrl }}/api/a6/create-baseline",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ { apiKey: $('准备执行参数').first().json.apiKey, ccbConclusion: $('解析CCB决策').first().json.ccbConclusion, acceptA5Risks: $('解析CCB决策').first().json.acceptA5Risks || $('A5 需求验证').first().json.decision === 'return_a1' || $('A5 需求验证').first().json.decision === 'return_a4' } }}",
        "options": {
          "timeout": 900000
        }
      }
    },
    {
      "id": "finish-success",
      "name": "完成通知",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3640,
        -120
      ],
      "parameters": {
        "jsCode": "const baseline = $json;\nreturn [{ json: {\n  status: 'completed',\n  message: '需求开发全流程完成，基线已创建。',\n  baselinePath: baseline.relativePath,\n  baselineId: baseline.baselineId,\n  requirementCount: baseline.requirementCount,\n  files: baseline.files\n}}];"
      }
    },
    {
      "id": "finish-no-baseline",
      "name": "审批未通过或要求返修",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3360,
        160
      ],
      "parameters": {
        "jsCode": "const ccb = $('解析CCB决策').first().json;\nreturn [{ json: {\n  status: ccb.decision === 'rejected' ? 'ccb_rejected' : 'ccb_revise_required',\n  message: ccb.decision === 'rejected' ? 'CCB 审批不通过，本次工作流终止。' : 'CCB 要求退回修改，本次工作流不创建基线。',\n  decision: ccb.decision,\n  comments: ccb.comments\n}}];"
      }
    },
    {
      "id": "a2-risk-summary",
      "name": "A2风险提示",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        0
      ],
      "parameters": {
        "jsCode": "const a2 = $json;\nreturn [{ json: {\n  status: a2.hasSevereIssues ? 'continue_with_a2_risks' : 'continue',\n  message: a2.hasSevereIssues ? 'A2 发现高/紧急风险，工作流继续进入 A3；这些问题将作为 A5/CCB 评审输入。' : 'A2 未发现高/紧急风险，继续进入 A3。',\n  a2RiskLevel: a2.a2RiskLevel ?? (a2.hasSevereIssues ? 'high' : 'normal'),\n  hasSevereIssues: Boolean(a2.hasSevereIssues),\n  issueCount: Array.isArray(a2.issues) ? a2.issues.length : 0,\n  severeIssueCount: Array.isArray(a2.rollbackIssues) ? a2.rollbackIssues.length : 0,\n  latestA2Report: a2.relativePath,\n  rollbackIssues: a2.rollbackIssues ?? []\n}}];"
      }
    }
