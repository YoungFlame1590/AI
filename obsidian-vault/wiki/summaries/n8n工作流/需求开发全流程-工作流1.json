{
  "name": "需求开发全流程（工作流1）",
  "nodes": [
    {
      "id": "start-webhook",
      "name": "启动需求开发流程",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "requirements-workflow-1/start",
        "responseMode": "onReceived",
        "options": {}
      }
    },
    {
      "id": "normalize-input",
      "name": "准备执行参数",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        260,
        0
      ],
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nconst stakeholders = body.stakeholders ?? [\n  { id: 'clerk', name: '门店店员' },\n  { id: 'manager', name: '门店店长' },\n  { id: 'operation', name: '总部运营管理员' },\n  { id: 'finance', name: '财务人员' },\n  { id: 'customer', name: '客户' },\n  { id: 'delivery', name: '配送/外协人员' },\n  { id: 'admin', name: '系统管理员' }\n];\nif (!body.apiKey) throw new Error('缺少 apiKey，请在启动 Webhook 请求体中传入百炼 API key。');\nreturn [{ json: {\n  projectName: body.projectName ?? '图文快印门店连锁管理系统',\n  apiKey: body.apiKey,\n  agentBaseUrl: (() => { const url = body.agentBaseUrl ?? 'http://127.0.0.1:8000'; return url.endsWith('/') ? url.slice(0, -1) : url; })(),\n  stakeholders,\n  roundsPerStakeholder: Number(body.roundsPerStakeholder ?? 1),\n  maxA2RollbackRounds: Number(body.maxA2RollbackRounds ?? 1),\n  ccbConclusion: body.ccbConclusion ?? '通过（无保留意见）'\n}}];"
      }
    },
    {
      "id": "a1b-batch",
      "name": "A1b 批量访谈并保存",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        540,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $('准备执行参数').first().json.agentBaseUrl }}/api/n8n/a1b-batch",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ { apiKey: $('准备执行参数').first().json.apiKey, stakeholders: $('准备执行参数').first().json.stakeholders, roundsPerStakeholder: $('准备执行参数').first().json.roundsPerStakeholder } }}",
        "options": {
          "timeout": 900000
        }
      }
    },
    {
      "id": "a2-analyze",
